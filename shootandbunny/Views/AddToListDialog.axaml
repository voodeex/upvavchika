<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="shootandbunny.Views.AddToListDialog"
        Title="Добавить в список"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        CanResize="False">
    <StackPanel Margin="28" Spacing="14">
        <TextBlock x:Name="BookTitleText" Foreground="#CDD6F4" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
        <TextBlock Text="Выберите список:" Foreground="#6C7086" FontSize="13"/>
        <ComboBox x:Name="StatusCombo" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" HorizontalAlignment="Stretch"/>
        <TextBlock x:Name="ErrorText" Foreground="#F38BA8" FontSize="12" IsVisible="False"/>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="Submit" Content="Добавить" Click="Submit_Click" Background="#89B4FA" Foreground="#1E1E2E" BorderThickness="0" Padding="18,9" CornerRadius="6" FontSize="13" FontWeight="Medium"/>
            <Button x:Name="Cancel" Content="Отмена" Click="Cancel_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="18,9" CornerRadius="6" FontSize="13"/>
        </StackPanel>
    </StackPanel>
</Window>
