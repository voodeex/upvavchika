<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="shootandbunny.Views.BookView"
             Background="#181825">
    <Grid RowDefinitions="70,*">
        <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#313244" BorderThickness="0,0,0,1" Padding="28,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="20">
                <Button x:Name="Back" Content="← Назад" Click="Back_Click" Background="Transparent" BorderThickness="0" Foreground="#89B4FA" FontSize="15" Padding="0"/>
                <TextBlock x:Name="Title" Foreground="#CDD6F4" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,40" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="30">
                    <Border Width="180" Height="270" Background="#313244" CornerRadius="12" ClipToBounds="True">
                        <Image x:Name="ImgCover" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Spacing="10" MaxWidth="480">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="★" Foreground="#F9E2AF" FontSize="22"/>
                            <TextBlock x:Name="Rating" Foreground="#F9E2AF" FontSize="22" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="Genres" Foreground="#6C7086" FontSize="13"/>
                        <TextBlock x:Name="Author" Foreground="#89B4FA" FontSize="14" Cursor="Hand" PointerPressed="Author_PointerPressed"/>
                        <TextBlock x:Name="Description" Foreground="#BAC2DE" FontSize="14" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button x:Name="Read" Content="Читать" Click="Read_Click" Background="#89B4FA" Foreground="#1E1E2E" Padding="16,8" CornerRadius="8" BorderThickness="0" FontSize="13"/>
                            <Button x:Name="ComplainBook" Content="Жалоба на книгу" Click="ComplainBook_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="16,8" CornerRadius="8" FontSize="13"/>
                            <Button x:Name="ComplainAuthor" Content="Жалоба на автора" Click="ComplainAuthor_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="16,8" CornerRadius="8" FontSize="13"/>
                            <Button x:Name="FreezeBook" Content="Заморозить книгу" Click="FreezeBook_Click" IsVisible="False" Background="#F38BA8" Foreground="#1E1E2E" Padding="16,8" CornerRadius="8" BorderThickness="0" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <Border x:Name="ComplaintPanel" IsVisible="False" Background="#1E1E2E" CornerRadius="10" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="ComplaintTitle" Foreground="#CDD6F4" FontSize="15" FontWeight="SemiBold"/>
                        <TextBox x:Name="ComplaintReason" PlaceholderText="Причина жалобы..." Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" CornerRadius="6" Padding="10,8" Height="80" AcceptsReturn="True"/>
                        <TextBlock x:Name="ComplaintError" Foreground="#F38BA8" FontSize="12" IsVisible="False"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="SubmitComplaint" Content="Отправить" Click="SubmitComplaint_Click" Background="#89B4FA" Foreground="#1E1E2E" Padding="14,7" CornerRadius="6" BorderThickness="0"/>
                            <Button x:Name="CancelComplaint" Content="Отмена" Click="CancelComplaint_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="14,7" CornerRadius="6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border x:Name="ReaderPanel" IsVisible="False" Background="#1E1E2E" CornerRadius="10" Padding="24">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Текст книги" Foreground="#CDD6F4" FontSize="16" FontWeight="SemiBold"/>
                            <Button x:Name="CloseReader" Content="Закрыть" Click="CloseReader_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="10,4" CornerRadius="6" FontSize="12"/>
                        </StackPanel>
                        <TextBlock x:Name="BookContent" Foreground="#BAC2DE" FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </Border>
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <TextBlock Text="Отзывы" Foreground="#CDD6F4" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="ShowReviewForm" Content="+ Написать отзыв" Click="ShowReviewForm_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="12,5" CornerRadius="6" FontSize="12"/>
                    </StackPanel>
                    <Border x:Name="ReviewFormPanel" IsVisible="False" Background="#1E1E2E" CornerRadius="10" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Оценка" Foreground="#CDD6F4" FontSize="13"/>
                            <ComboBox x:Name="ReviewRating" Width="120" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A">
                                <ComboBoxItem Content="1 ★"/>
                                <ComboBoxItem Content="2 ★"/>
                                <ComboBoxItem Content="3 ★"/>
                                <ComboBoxItem Content="4 ★"/>
                                <ComboBoxItem Content="5 ★"/>
                            </ComboBox>
                            <TextBlock Text="Текст отзыва" Foreground="#CDD6F4" FontSize="13"/>
                            <TextBox x:Name="ReviewText" PlaceholderText="Напишите отзыв..." Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" CornerRadius="6" Padding="10,8" Height="80" AcceptsReturn="True"/>
                            <TextBlock x:Name="ReviewError" Foreground="#F38BA8" FontSize="12" IsVisible="False"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="SubmitReview" Content="Опубликовать" Click="SubmitReview_Click" Background="#89B4FA" Foreground="#1E1E2E" Padding="14,7" CornerRadius="6" BorderThickness="0"/>
                                <Button x:Name="CancelReview" Content="Отмена" Click="CancelReview_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="14,7" CornerRadius="6"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="NoReviewsText" Text="Отзывов пока нет." Foreground="#6C7086" FontSize="14" IsVisible="False"/>
                    <StackPanel x:Name="ReviewsPanel" Spacing="12"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
