<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="shootandbunny.Views.FreezeDialog"
        Title="Заморозить пользователя"
        Width="420" Height="240"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        CanResize="False">
    <StackPanel Margin="28" Spacing="14">
        <TextBlock x:Name="TitleText" Foreground="#CDD6F4" FontSize="17" FontWeight="Bold"/>
        <TextBlock Text="Укажите причину заморозки:" Foreground="#6C7086" FontSize="13"/>
        <TextBox x:Name="ReasonBox" PlaceholderText="Причина..." Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" CornerRadius="6" Padding="10,8" Height="70" AcceptsReturn="True"/>
        <TextBlock x:Name="ErrorText" Foreground="#F38BA8" FontSize="12" IsVisible="False"/>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="Submit" Content="Заморозить" Click="Submit_Click" Background="#F38BA8" Foreground="#1E1E2E" BorderThickness="0" Padding="18,9" CornerRadius="6" FontSize="13" FontWeight="Medium"/>
            <Button x:Name="Cancel" Content="Отмена" Click="Cancel_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="18,9" CornerRadius="6" FontSize="13"/>
        </StackPanel>
    </StackPanel>
</Window>
