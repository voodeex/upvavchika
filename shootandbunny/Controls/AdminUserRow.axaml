<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="shootandbunny.Controls.AdminUserRow">
    <Border Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="10" Padding="16,12">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock x:Name="NameText" Foreground="#CDD6F4" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border x:Name="RoleBadgeAdmin" IsVisible="False" Background="#F38BA8" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="Администратор" Foreground="#1E1E2E" FontSize="12" FontWeight="Medium"/>
                </Border>
                <Border x:Name="RoleBadgeAuthor" IsVisible="False" Background="#A6E3A1" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="Автор" Foreground="#1E1E2E" FontSize="12" FontWeight="Medium"/>
                </Border>
                <Border x:Name="RoleBadgeReader" IsVisible="False" Background="#313244" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="Читатель" Foreground="#BAC2DE" FontSize="12" FontWeight="Medium"/>
                </Border>
                <Border x:Name="FrozenBadge" IsVisible="False" Background="#F38BA8" CornerRadius="4" Padding="8,3">
                    <TextBlock Text="Заморожен" Foreground="#1E1E2E" FontSize="12"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="FreezeBtn" IsVisible="False" Content="Заморозить" Click="Freeze_Click" Background="#F38BA8" Foreground="#1E1E2E" BorderThickness="0" Padding="12,5" CornerRadius="6" FontSize="12"/>
                <Button x:Name="UnfreezeBtn" IsVisible="False" Content="Разморозить" Click="Unfreeze_Click" Background="#A6E3A1" Foreground="#1E1E2E" BorderThickness="0" Padding="12,5" CornerRadius="6" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
