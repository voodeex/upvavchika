<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="shootandbunny.Controls.AuthorBookCard">
    <Border Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="10" Padding="16">
        <Grid ColumnDefinitions="Auto,16,*">
            <Border Grid.Column="0" Width="60" Height="88" Background="#313244" CornerRadius="6" ClipToBounds="True">
                <Image x:Name="CoverImage" Stretch="UniformToFill"/>
            </Border>
            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="#CDD6F4" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock x:Name="GenresText" Foreground="#6C7086" FontSize="12"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="★" Foreground="#F9E2AF" FontSize="13"/>
                        <TextBlock x:Name="RatingText" Foreground="#F9E2AF" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border x:Name="FrozenBadge" IsVisible="False" Background="#F38BA8" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Заморожена" Foreground="#1E1E2E" FontSize="11"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="EditBtn" Content="Редактировать" Click="Edit_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#CDD6F4" Padding="12,5" CornerRadius="6" FontSize="12"/>
                    <Button x:Name="UnfreezeBtn" Content="Оспорить" Click="Unfreeze_Click" IsVisible="False" Background="Transparent" BorderBrush="#F38BA8" BorderThickness="1" Foreground="#F38BA8" Padding="12,5" CornerRadius="6" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
