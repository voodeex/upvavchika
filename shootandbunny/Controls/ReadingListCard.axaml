<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="shootandbunny.Controls.ReadingListCard">
    <Border Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="10" Padding="16">
        <Grid ColumnDefinitions="Auto,16,*">
            <Border Grid.Column="0" Width="60" Height="88" Background="#313244" CornerRadius="6" ClipToBounds="True">
                <Image x:Name="CoverImage" Stretch="UniformToFill"/>
            </Border>
            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="#CDD6F4" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Cursor="Hand"/>
                <TextBlock x:Name="AuthorText" Foreground="#89B4FA" FontSize="13"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="★" Foreground="#F9E2AF" FontSize="13"/>
                    <TextBlock x:Name="RatingText" Foreground="#F9E2AF" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="StatusCombo" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>
                    <Button x:Name="RemoveBtn" Content="✕" Click="Remove_Click" Background="Transparent" BorderBrush="#45475A" BorderThickness="1" Foreground="#6C7086" Padding="8,4" CornerRadius="6" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
