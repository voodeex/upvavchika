<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="shootandbunny.Controls.ProfileReviewCard">
    <Border Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" CornerRadius="10" Padding="16">
        <StackPanel Spacing="6">
            <TextBlock x:Name="BookTitleText" Foreground="#89B4FA" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Cursor="Hand"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="★" Foreground="#F9E2AF" FontSize="14"/>
                    <TextBlock x:Name="RatingText" Foreground="#F9E2AF" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="DateText" Foreground="#6C7086" FontSize="12" VerticalAlignment="Center"/>
                <Border x:Name="FrozenBadge" IsVisible="False" Background="#F38BA8" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="Заморожен" Foreground="#1E1E2E" FontSize="11"/>
                </Border>
            </StackPanel>
            <TextBlock x:Name="ReviewBodyText" Foreground="#BAC2DE" FontSize="14" TextWrapping="Wrap" IsVisible="False"/>
            <Button x:Name="UnfreezeBtn" Content="Оспорить заморозку" Click="Unfreeze_Click" IsVisible="False" Background="Transparent" BorderBrush="#F38BA8" BorderThickness="1" Foreground="#F38BA8" Padding="12,5" CornerRadius="6" FontSize="12" HorizontalAlignment="Left"/>
        </StackPanel>
    </Border>
</UserControl>
